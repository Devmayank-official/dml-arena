# ============================================
# DML Arena - Environment Variables Reference
# ============================================
# Copy this file and rename to .env
# Fill in the values from your respective dashboards.
#
# NOTE: VITE_SUPABASE_* variables are auto-configured
# by the managed backend and should NOT be changed manually.
# ============================================

# --- Supabase (Auto-configured) ---
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# --- Razorpay Payment Gateway ---
# Get these from: https://dashboard.razorpay.com/app/keys
# The private keys are stored as backend secrets (edge function env vars), NOT in .env
#
# RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX        # Razorpay Key ID
# RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXX        # Razorpay Key Secret (private, edge functions only)
# RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXX    # Webhook secret for signature verification

# --- Razorpay Frontend Key (safe to expose) ---
# This is the publishable key used by the Razorpay checkout widget on the frontend.
VITE_RAZORPAY_KEY_ID="rzp_test_PLACEHOLDER"

# ============================================
# BACKEND SECRETS (Edge Functions)
# ============================================
# The following secrets must be added via your Supabase project's Edge Function secrets:
#
# 1. AI_GATEWAY_API_KEY     - Fallback AI gateway API key
# 2. OPENROUTER_API_KEY     - (Recommended) OpenRouter API key for 55+ models
# 3. RAZORPAY_KEY_ID        - Your Razorpay Key ID
# 4. RAZORPAY_KEY_SECRET    - Your Razorpay Key Secret
# 5. RAZORPAY_WEBHOOK_SECRET - Webhook signature verification secret
#
# These are available as Deno.env.get('SECRET_NAME') in edge functions.
# ============================================
